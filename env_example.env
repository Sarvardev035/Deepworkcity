# ============================================================
#  DEEP WORK CITY — .env (copy this to .env and fill in)
# ============================================================

# App
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://deepwork.city

# MongoDB Atlas (create free cluster at mongodb.com/atlas)
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/deepworkcity?retryWrites=true&w=majority

# Redis (Upstash free tier at upstash.com, or local)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=

# JWT — change this to a long random string!
JWT_SECRET=change_this_to_64_char_random_string_in_production

# Launch date for 48h promo countdown (ISO 8601 with timezone)
# Set this to your actual deploy time
LAUNCH_DATE=2026-03-17T07:00:00+05:00

# Google OAuth (console.cloud.google.com → Credentials → OAuth 2.0)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# SMS via Playmobile (UZ provider: playmobile.uz)
SMS_LOGIN=your_playmobile_login
SMS_PASS=your_playmobile_password

# Payme (cabinet.payme.uz → My Apps)
PAYME_MERCHANT_ID=your_payme_merchant_id
PAYME_KEY=your_payme_key

# Click (my.click.uz → Developers → Merchant API)
CLICK_MERCHANT_ID=your_click_merchant_id
CLICK_SERVICE_ID=your_click_service_id
CLICK_SECRET_KEY=your_click_secret

# Paynet (paynet.uz → Merchant → Settings)
PAYNET_SHOP_ID=your_paynet_shop_id
PAYNET_KEY=your_paynet_key

# Admin — first user with this phone/email gets admin access on first login
# Set to your phone number BEFORE deploying
ADMIN_PHONE=+998901234567
